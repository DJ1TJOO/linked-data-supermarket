@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix terms: <https://dj1tjoo.github.io/linked-data-supermarket/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

terms:CostPrice a rdfs:Class ;
    rdfs:label "Cost Price" ;
    rdfs:comment "A record of the wholesale cost for a product at a specific time." .

terms:isDiscounted a rdf:Property ;
    rdfs:label "Is Discounted" ;
    rdfs:comment "Whether the product is discounted." ;
    rdfs:range xsd:boolean .

terms:lossRate a rdf:Property ;
    rdfs:label "Loss Rate" ;
    rdfs:comment "The percentage of product lost during processing." .

terms:orderQuantity a rdf:Property ;
    rdfs:label "Order Quantity" ;
    rdfs:comment "The quantity of the product ordered." ;
    rdfs:range schema:QuantitativeValue .

terms:perKG a schema:QuantitativeValue ;
    rdfs:label "Per KG" ;
    rdfs:comment "The one unit per kilogram." ;
    schema:unitCode "KGM" ;
    schema:value 1 .

