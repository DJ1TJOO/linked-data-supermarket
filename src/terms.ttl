@prefix : <https://dj1tjoo.github.io/linked-data-supermarket/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@base <https://dj1tjoo.github.io/linked-data-supermarket/terms/> .

<https://dj1tjoo.github.io/linked-data-supermarket/terms/> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  https://schema.org/unitCode
schema:unitCode rdf:type owl:AnnotationProperty .


###  https://schema.org/value
schema:value rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  https://schema.org/Number
schema:Number rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://dj1tjoo.github.io/linked-data-supermarket/terms/availableIn
:availableIn rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Vegetable ;
             rdfs:range :Availability ;
             rdfs:comment "Specifies when a vegetable is sold." ;
             rdfs:label "has availability" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/growingCondition
:growingCondition rdf:type owl:ObjectProperty ;
                  rdfs:domain :Vegetable ;
                  rdfs:range :GrowingCondition ;
                  rdfs:comment "Relates a vegetable to its environmental requirements for growth." ;
                  rdfs:label "growing condition" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/growsIn
:growsIn rdf:type owl:ObjectProperty ;
         rdfs:domain :Vegetable ;
         rdfs:range :Season ;
         rdfs:comment "Indicates when a vegetable is grown." ;
         rdfs:label "grows in season" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/hasColor
:hasColor rdf:type owl:ObjectProperty ;
          rdfs:domain :Vegetable ;
          rdfs:range :Color ;
          rdfs:comment "Associates a vegetable with its colour." ;
          rdfs:label "has colour" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/hasNutritionalValue
:hasNutritionalValue rdf:type owl:ObjectProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :Vegetable ;
                     rdfs:range :NutritionalValue ;
                     rdfs:comment "Links a vegetable to its nutritional information." ;
                     rdfs:label "has nutritional value" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/orderQuantity
:orderQuantity rdf:type owl:ObjectProperty ;
               rdfs:domain schema:Order ;
               rdfs:range schema:QuantitativeValue ;
               rdfs:comment "The quantity of the product ordered." ;
               rdfs:label "Order Quantity" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/storedLike
:storedLike rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Vegetable ;
            rdfs:range :StorageRequirement ;
            rdfs:comment "Specifies how a vegetable should be stored." ;
            rdfs:label "has storage requirement" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/varientOf
:varientOf rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain schema:Product ;
           rdfs:range :Vegetable .


###  https://schema.org/itemOffered
schema:itemOffered rdf:type owl:ObjectProperty .


###  https://schema.org/priceSpecification
schema:priceSpecification rdf:type owl:ObjectProperty .


###  https://schema.org/validFrom
schema:validFrom rdf:type owl:ObjectProperty .


###  https://schema.org/validUntil
schema:validUntil rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  https://dj1tjoo.github.io/linked-data-supermarket/terms/commonVariety
:commonVariety rdf:type owl:DatatypeProperty ;
               rdfs:domain :Vegetable ;
               rdfs:range xsd:string ;
               rdfs:comment "Varieties most common for a specific vegetable." ;
               rdfs:label "Common variety" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/fiber
:fiber rdf:type owl:DatatypeProperty ;
       rdfs:domain :NutritionalValue ;
       rdfs:range xsd:double ;
       rdfs:comment "Fiber content of the vegetable." ;
       rdfs:label "Fiber" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/healthBenefits
:healthBenefits rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :Vegetable ;
                rdfs:range xsd:string ;
                rdfs:comment "Notable health benefits or uses." ;
                rdfs:label "Health benefits" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/isDiscounted
:isDiscounted rdf:type owl:DatatypeProperty ;
              rdfs:domain schema:Offer ;
              rdfs:range xsd:boolean ;
              rdfs:comment "Whether the product is discounted." ;
              rdfs:label "Is Discounted" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/kcal
:kcal rdf:type owl:DatatypeProperty ;
      rdfs:domain :NutritionalValue ;
      rdfs:range xsd:integer ;
      rdfs:comment "Calorie content of the vegetable." ;
      rdfs:label "Calories (kcal)" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/lossRate
:lossRate rdf:type owl:DatatypeProperty ;
          rdfs:domain schema:Product ;
          rdfs:range xsd:double ;
          rdfs:comment "The percentage of product lost during processing." ;
          rdfs:label "Loss Rate" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/name
:name rdf:type owl:DatatypeProperty ;
      rdfs:domain :Vegetable ;
      rdfs:range xsd:string ;
      rdfs:comment "Common name of the vegetable." ;
      rdfs:label "Name" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/origin
:origin rdf:type owl:DatatypeProperty ;
        rdfs:domain :Vegetable ;
        rdfs:range xsd:string ;
        rdfs:comment "Geographic region where the vegetable is commonly grown." ;
        rdfs:label "Origin" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/protein
:protein rdf:type owl:DatatypeProperty ;
         rdfs:domain :NutritionalValue ;
         rdfs:range xsd:double ;
         rdfs:comment "Protein content of the vegetable." ;
         rdfs:label "Protein" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/scientificName
:scientificName rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :Vegetable ;
                rdfs:range xsd:string ;
                rdfs:comment "Botanical name of the vegetable." ;
                rdfs:label "Scientific name" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/shelfLife
:shelfLife rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Vegetable ;
           rdfs:range xsd:integer ;
           rdfs:comment "Average length of time for which an item remains fit for consumption in days." ;
           rdfs:label "Shelf life" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/value
:value rdf:type owl:DatatypeProperty ;
       rdfs:domain :Color ;
       rdfs:range xsd:string ;
       rdfs:comment "Literal value representing a colour." ;
       rdfs:label "Value" .


#################################################################
#    Classes
#################################################################

###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Availability
:Availability rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:oneOf ( :Seasonal
                                                :YearRound
                                              )
                                  ] ;
              rdfs:comment "When a vegetable is sold." ;
              rdfs:label "Availability" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Climate
:Climate rdf:type owl:Class ;
         owl:equivalentClass [ rdf:type owl:Class ;
                               owl:oneOf ( :Cool
                                           :Warm
                                         )
                             ] ;
         rdfs:subClassOf :GrowingCondition ;
         rdfs:comment "Environmental requirement related to temperature conditions." ;
         rdfs:label "Climate" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Color
:Color rdf:type owl:Class ;
       rdfs:comment "Colour of the vegetable." ;
       rdfs:label "Colour" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/CostPrice
:CostPrice rdf:type owl:Class ;
           rdfs:subClassOf [ rdf:type owl:Restriction ;
                             owl:onProperty schema:itemOffered ;
                             owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass schema:Product
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty schema:priceSpecification ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass schema:PriceSpecification
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty schema:validFrom ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass schema:Date
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty schema:validUntil ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass schema:Date
                           ] ;
           rdfs:comment "A record of the wholesale cost for a product at a specific time." ;
           rdfs:label "Cost Price" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/GrowingCondition
:GrowingCondition rdf:type owl:Class ;
                  rdfs:comment "Environmental requirements for growth (Soil, Water, Sunlight, Climate)." ;
                  rdfs:label "Growing condition" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/NutritionalValue
:NutritionalValue rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty :fiber ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:double
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :kcal ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:integer
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :protein ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:double
                                  ] ;
                  rdfs:comment "Nutritional information: calories, protein and fiber." ;
                  rdfs:label "Nutritional value" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Season
:Season rdf:type owl:Class ;
        owl:equivalentClass [ rdf:type owl:Class ;
                              owl:oneOf ( :Fall
                                          :Spring
                                          :Summer
                                          :Winter
                                        )
                            ] ;
        rdfs:comment "When a vegetable is grown." ;
        rdfs:label "Season" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Soil
:Soil rdf:type owl:Class ;
      owl:equivalentClass [ rdf:type owl:Class ;
                            owl:oneOf ( :Coastal
                                        :Loose
                                        :Moist
                                        :Rich
                                        :Salty
                                        :WellDrained
                                        :Wet
                                      )
                          ] ;
      rdfs:subClassOf :GrowingCondition ;
      rdfs:comment "Environmental requirement related to soil type." ;
      rdfs:label "Soil" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/StorageRequirement
:StorageRequirement rdf:type owl:Class ;
                    owl:equivalentClass [ rdf:type owl:Class ;
                                          owl:oneOf ( :CoolDark
                                                      :CoolDry
                                                      :Refrigeration
                                                    )
                                        ] ;
                    rdfs:comment "How to store the vegetable." ;
                    rdfs:label "Storage requirement" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Sunlight
:Sunlight rdf:type owl:Class ;
          owl:equivalentClass [ rdf:type owl:Class ;
                                owl:oneOf ( :FullSunlight
                                            :PartialShade
                                            :ShadedEnvironment
                                          )
                              ] ;
          rdfs:subClassOf :GrowingCondition ;
          rdfs:comment "Environmental requirement related to light exposure." ;
          rdfs:label "Sunlight" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Vegetable
:Vegetable rdf:type owl:Class ;
           rdfs:subClassOf [ rdf:type owl:Restriction ;
                             owl:onProperty :growingCondition ;
                             owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :GrowingCondition
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :growsIn ;
                             owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Season
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasColor ;
                             owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Color
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :availableIn ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Availability
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasNutritionalValue ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :NutritionalValue
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :storedLike ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :StorageRequirement
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :growingCondition ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Climate
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :growingCondition ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Soil
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :growingCondition ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Sunlight
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :growingCondition ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Watering
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :name ;
                             owl:minCardinality "1"^^xsd:nonNegativeInteger
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :origin ;
                             owl:minCardinality "1"^^xsd:nonNegativeInteger
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :scientificName ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onDataRange xsd:string
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :shelfLife ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onDataRange xsd:integer
                           ] ;
           owl:disjointWith schema:Product ;
           owl:hasKey ( :scientificName
                      ) ;
           rdfs:comment "An edible plant or part of a plant grown for consumption." ;
           rdfs:label "Vegetable" .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Watering
:Watering rdf:type owl:Class ;
          owl:equivalentClass [ rdf:type owl:Class ;
                                owl:oneOf ( :Moderate
                                          )
                              ] ;
          rdfs:subClassOf :GrowingCondition ;
          rdfs:comment "Environmental requirement related to water supply." ;
          rdfs:label "Watering" .


###  https://schema.org/Date
schema:Date rdf:type owl:Class .


###  https://schema.org/Offer
schema:Offer rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty :isDiscounted ;
                               owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onDataRange xsd:boolean
                             ] .


###  https://schema.org/Order
schema:Order rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty :orderQuantity ;
                               owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass schema:QuantitativeValue
                             ] .


###  https://schema.org/PriceSpecification
schema:PriceSpecification rdf:type owl:Class .


###  https://schema.org/Product
schema:Product rdf:type owl:Class ;
               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty :varientOf ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :Vegetable
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :lossRate ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onDataRange xsd:double
                               ] .


###  https://schema.org/QuantitativeValue
schema:QuantitativeValue rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Coastal
:Coastal rdf:type owl:NamedIndividual ,
                  :Soil .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Cool
:Cool rdf:type owl:NamedIndividual ,
               :Climate ;
      owl:differentFrom :Warm .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/CoolDark
:CoolDark rdf:type owl:NamedIndividual ,
                   :StorageRequirement .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/CoolDry
:CoolDry rdf:type owl:NamedIndividual ,
                  :StorageRequirement .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Fall
:Fall rdf:type owl:NamedIndividual ,
               :Season .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/FullSunlight
:FullSunlight rdf:type owl:NamedIndividual ,
                       :Sunlight .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Loose
:Loose rdf:type owl:NamedIndividual ,
                :Soil .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Moderate
:Moderate rdf:type owl:NamedIndividual ,
                   :Watering .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Moist
:Moist rdf:type owl:NamedIndividual ,
                :Soil .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/PartialShade
:PartialShade rdf:type owl:NamedIndividual ,
                       :Sunlight .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Refrigeration
:Refrigeration rdf:type owl:NamedIndividual ,
                        :StorageRequirement .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Rich
:Rich rdf:type owl:NamedIndividual ,
               :Soil .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Salty
:Salty rdf:type owl:NamedIndividual ,
                :Soil .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Seasonal
:Seasonal rdf:type owl:NamedIndividual ,
                   :Availability ;
          owl:differentFrom :YearRound .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/ShadedEnvironment
:ShadedEnvironment rdf:type owl:NamedIndividual ,
                            :Sunlight .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Spring
:Spring rdf:type owl:NamedIndividual ,
                 :Season .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Summer
:Summer rdf:type owl:NamedIndividual ,
                 :Season .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Warm
:Warm rdf:type owl:NamedIndividual ,
               :Climate .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/WellDrained
:WellDrained rdf:type owl:NamedIndividual ,
                      :Soil .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Wet
:Wet rdf:type owl:NamedIndividual ,
              :Soil .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/Winter
:Winter rdf:type owl:NamedIndividual ,
                 :Season .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/YearRound
:YearRound rdf:type owl:NamedIndividual ,
                    :Availability .


###  https://dj1tjoo.github.io/linked-data-supermarket/terms/perKG
:perKG rdf:type owl:NamedIndividual ,
                schema:QuantitativeValue ;
       rdfs:comment "The one unit per kilogram." ;
       rdfs:label "Per KG" ;
       schema:unitCode "KGM" ;
       schema:value "1"^^schema:Number .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Color
                :Soil
                :Sunlight
                :Watering
              )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :Coastal
                        :Loose
                        :Moist
                        :Rich
                        :Salty
                        :WellDrained
                        :Wet
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :CoolDark
                        :CoolDry
                        :Refrigeration
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :Fall
                        :Spring
                        :Summer
                        :Winter
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :FullSunlight
                        :PartialShade
                        :ShadedEnvironment
                      )
] .


